# Copy to `.env.local` (and/or `.env`) and fill in values.

# legacy | hybrid | otp — hybrid shows OTP UI; legacy keeps password login only
VITE_AUTH_MIGRATION_MODE=hybrid

# API Gateway base URL (no trailing slash). Vite dev proxies /api/* → this host (see vite.config.ts).
VITE_API_GATEWAY_URL=https://xxxxxxxx.execute-api.region.amazonaws.com

# Amazon Cognito (User pool overview + App integration → App clients) — public identifiers only
VITE_COGNITO_USER_POOL_ID=ap-south-2_REPLACE_WITH_YOUR_POOL_ID
VITE_COGNITO_USER_POOL_CLIENT_ID=REPLACE_WITH_YOUR_APP_CLIENT_ID

# Optional: only if you use a different region than the pool
# VITE_COGNITO_REGION=ap-south-2

# Optional: override legacy login API URL
# VITE_LEGACY_AUTH_ENDPOINT=https://...

# Optional: Lambda/API URL for user_bootstrap_handler (sync Cognito → Users table)
# VITE_USER_BOOTSTRAP_ENDPOINT=https://xxxx.execute-api.region.amazonaws.com/default/user_bootstrap_handler

# --- OTP Lambda env (set in API Gateway / Lambda console, not VITE_) ---
# COGNITO_USER_POOL_ID=
# COGNITO_USER_POOL_CLIENT_ID=
# COGNITO_CLIENT_SECRET=
# COGNITO_REGION=
# ALLOWED_ORIGIN=https://your-spa-origin

# Backward-compatible aliases accepted by lambda/auth_otp_handler.py:
# COGNITO_CLIENT_ID=
# COGNITO_USER_POOL_CLIENT_SECRET=

