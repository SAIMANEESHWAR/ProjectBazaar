# Copy to `.env.local` for local overrides (do not commit secrets).

# Live Mock Interview results API (g20pktgtz9) — defaults in services/liveMockInterviewApi.ts; dev uses /dev-api/live-mock-interview proxy
# VITE_LIVE_INTERVIEW_DB_API_URL=https://g20pktgtz9.execute-api.ap-south-2.amazonaws.com/default/LiveMockinterview

# ATS + Fix My Resume (API Gateway 8ysn1do8kb, ap-south-2) — defaults in services/atsService.ts
# VITE_ATS_SCORER_ENDPOINT=https://8ysn1do8kb.execute-api.ap-south-2.amazonaws.com/default/ats_scorer_handler
# VITE_FIX_RESUME_ENDPOINT=https://55if5jjozg.execute-api.ap-south-2.amazonaws.com/default/fix_resume_handler

# Portfolio Builder v2 — lambda/portfolio-builder/ (defaults in services/portfolioBuilderService.ts)
# VITE_PORTFOLIO_BUILDER_ENDPOINT=https://YOUR_API.execute-api.ap-south-2.amazonaws.com/default/portfolio_builder_handler

# Login API — defaults to API Gateway URL in lib/apiConfig.ts; set here to point elsewhere.
# VITE_LOGIN_API_URL=https://xlxus7dr78.execute-api.ap-south-2.amazonaws.com/User_login_signup

# Subscription API — set after deploying lambda/subscription_handler.py + API Gateway
# VITE_SUBSCRIPTION_API_URL=https://YOUR_API.execute-api.ap-south-2.amazonaws.com/default/subscription

# Feature entitlement API — lambda/feature_entitlement.py (5 free uses / trial gating)
# VITE_FEATURE_ENTITLEMENT_API_URL=https://99j6d2af9b.execute-api.ap-south-2.amazonaws.com/default/feature_entitlement

# --- Razorpay (AWS Lambda environment variables — never commit secrets) ---
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx        # or rzp_live_xxx in production
# RAZORPAY_KEY_SECRET=xxxxxxxx               # server-side only (course + subscription Lambdas)
# Use test keys (rzp_test_*) only with test mode; live keys only in production.
# Frontend receives key from create order API responses — no NEXT_PUBLIC_RAZORPAY_KEY_ID required.

# Google OAuth redirect — must match Google Cloud "Authorized redirect URIs" exactly.
# Production: https://codexcareer.com/auth
# VITE_GOOGLE_REDIRECT_URI=https://codexcareer.com/auth

# --- Login Lambda only (AWS Console → Environment variables) ---
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
# ALLOWED_ORIGIN=https://codexcareer.com
# ALLOWED_ORIGINS=https://codexcareer.com,http://localhost:5173
# APP_BASE_URL=https://codexcareer.com
#
# Gmail SMTP (email verification — App Password, not your normal Gmail password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-gmail@gmail.com
# SMTP_APP_PASSWORD=xxxxxxxxxxxxxxxx
# SMTP_FROM_NAME=CodeXCareer
# SMTP_FROM_EMAIL=your-gmail@gmail.com

# --- fetch_jobs_firecrawl Lambda only (AWS Console → Environment variables) ---
# Package email_service.py with fetch_jobs_firecrawl.py in the same Lambda zip.
# FIRECRAWL_API_KEY=fc-xxxxx
# JOBS_TABLE=JobListings
# APP_BASE_URL=https://codexcareer.com
# JOB_EMAIL_DIGEST_LIMIT=5
# JOB_HUNT_URL=https://codexcareer.com/dashboard
# SOCKET_SERVER_URL=https://projectbazaarsocketserver.onrender.com
# SMTP_USER=your-gmail@gmail.com
# SMTP_APP_PASSWORD=xxxxxxxxxxxxxxxx

# --- Sanity CMS (frontend read-only) ---
# VITE_SANITY_PROJECT_ID=your_project_id
# VITE_SANITY_DATASET=production
# VITE_SANITY_API_VERSION=2025-01-01
# VITE_SANITY_USE_CDN=true

# --- Analytics / GTM ---
# Use GTM as the tag management layer. Example: GTM-XXXXXXX
# VITE_GTM_ID=GTM-XXXXXXX
# Optional: GA4 measurement ID (hardcoded in index.html as G-XEJHXMYWY0)
# VITE_GA4_MEASUREMENT_ID=G-XEJHXMYWY0
# UTM attribution TTL in localStorage (default 90 days)
# VITE_ATTRIBUTION_TTL_DAYS=90

# --- Company Compare (lambda/company_compare_handler, ap-south-2) ---
# Default in lib/companyCompareApi.ts — override here if needed:
# VITE_COMPANY_COMPARE_API_URL=https://o14vqopl3l.execute-api.ap-south-2.amazonaws.com/default/company_compare_handler
# VITE_COMPANY_COMPARE_ADMIN_KEY=your-long-random-secret
# VITE_COMPANY_COMPARE_OFFLINE=true

# --- Login Lambda: Google Sheets UTM sync (AWS Console → Environment variables) ---
# See docs/GOOGLE_SHEETS_SETUP.md — NEVER commit service account JSON to git.
# Option A: Apps Script web app URL
# GOOGLE_SHEETS_WEBAPP_URL=https://script.google.com/macros/s/XXXXXXXX/exec
# Option B: Service account + Sheets API (paste full JSON as one line, or use split vars below)
# GOOGLE_SHEET_ID=your_spreadsheet_id
# GOOGLE_SHEET_TAB=UTM Signups
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...@....iam.gserviceaccount.com",...}
# GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@xxx.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
